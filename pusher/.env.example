# Copy this file to ".env" (same folder) and fill in your values.
# The .env file stays on your PC only — never commit it or put it on GitHub.

# From Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Use the SERVICE ROLE key here (Settings → API → service_role). Secret — PC only.
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key...

# Must match the "Board name" you enter in the app on every device.
BOARD_ID=my-week

# Full paths to your sources (Windows examples shown).
STATUS_FILE=D:\Coding\App_generation\PROJECT_STATUS.md
DB_DIR=D:\#########Database

# How many folder levels deep to read under DB_DIR.
MAX_DEPTH=4
